{
    "name": "@plurnk/plurnk-mimetypes-application-json",
    "version": "0.5.5",
    "description": "application/json and application/jsonc mimetype handler for plurnk-service.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "plurnk": {
        "kind": "mimetype",
        "handlers": [
            {
                "name": "application/json",
                "glyph": "📋",
                "extensions": [
                    ".json"
                ]
            },
            {
                "name": "application/jsonc",
                "glyph": "📋",
                "extensions": [
                    ".jsonc"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build && (git config core.hooksPath .githooks || true)",
        "deps:fresh": "npm outdated",
        "prepublishOnly": "npm run deps:fresh && npm audit --audit-level=moderate && npm test"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1"
    },
    "devDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.31",
        "@types/node": "^26.0.0",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "0.16.0"
    }
}
